# 기본: 텍스트 파일은 LF로 정규화
* text=auto eol=lf

# STM32 펌웨어 소스
*.c     text eol=lf
*.h     text eol=lf
*.s     text eol=lf
*.S     text eol=lf
*.ld    text eol=lf
*.ioc   text eol=lf

# CubeIDE 프로젝트 파일 (Windows에서 생성되므로 CRLF 허용)
.project    text eol=crlf
.cproject   text eol=crlf
*.mxproject text eol=crlf

# 바이너리 파일
*.a     binary
*.o     binary
*.elf   binary
*.bin   binary
*.hex   binary
